{
  "tasks": {
    "start": "deno run -A --unstable-kv --env-file=.env server/main.ts",
    "dev": "deno run -A --unstable-kv --env-file=.env --watch server/main.ts",
    "up": "docker compose up vector-db -d && deno task dev",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "deno check server/main.ts",
    "test": "deno test -A --unstable-kv --env-file=.env --ignore=.agent",
    "test:watch": "deno test -A --unstable-kv --env-file=.env --watch --ignore=.agent",
    "play": "deno run -A --env-file=.env play.ts",
    "play-ink": "deno run -A --env-file=.env server/ink_play.tsx",
    "bot:dev": "cd d100-bot && deno task dev",
    "bot:start": "cd d100-bot && deno task start",
    "bot:deploy": "cd d100-bot && deno task deploy",
    "bot:test": "cd d100-bot && deno task test"
  },
  "imports": {
    "hono": "npm:hono@^4.0.0",
    "zod": "npm:zod@^3.22.4",
    "react": "npm:react@^18.2.0",
    "ink": "npm:ink@^5.0.0",
    "ink-select-input": "npm:ink-select-input@^5.0.0",
    "ink-box": "npm:ink-box@^1.0.0",
    "ink-gradient": "npm:ink-gradient@^3.0.0",
    "ink-big-text": "npm:ink-big-text@^2.0.0",
    "ink-text-input": "npm:ink-text-input@^5.0.0",
    "@langchain/langgraph": "npm:@langchain/langgraph@^0.2.0",
    "@langchain/core": "npm:@langchain/core@^0.3.0",
    "@langchain/openai": "npm:@langchain/openai@^0.3.0",
    "@langchain/google-genai": "npm:@langchain/google-genai@^0.1.0",
    "@xenova/transformers": "npm:@xenova/transformers@^2.15.0",
    "blessed": "npm:neo-blessed@^0.2.0",
    "inquirer": "npm:inquirer@^9.0.0",
    "picocolors": "npm:picocolors@^1.0.0",
    "@std/async": "jsr:@std/async@^0.224.0",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "scrypt": "https://deno.land/x/scrypt@v4.2.1/mod.ts",
    "djwt": "https://deno.land/x/djwt@v3.0.2/mod.ts"
  },
  "nodeModulesDir": "auto",
  "allowScripts": ["npm:sharp@0.32.6"]
}
