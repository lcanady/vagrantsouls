{
  "tasks": {
    "dev":    "deno run --allow-all --unstable-kv --env-file=.env --watch src/index.ts",
    "start":  "deno run --allow-all --unstable-kv --env-file=.env src/index.ts",
    "deploy": "deno run --allow-all --env-file=.env src/deploy-commands.ts",
    "test":   "deno test --allow-all --unstable-kv src/tests/"
  },
  "imports": {
    "discord.js":   "npm:discord.js@^14.16.0",
    "@std/assert":  "jsr:@std/assert@^1.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["ES2022", "DOM", "deno.ns", "deno.unstable"]
  }
}
