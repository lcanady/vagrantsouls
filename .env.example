# ─── API Server ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: switch LLM provider
# OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB URL — defaults to http://localhost:8001 when running via deno task up
# In Docker Compose, this is set automatically to http://vector-db:8000
CHROMA_URL=http://localhost:8001

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications → Your App → Bot
DISCORD_TOKEN=your_bot_token_here

# From Applications page → General Information → Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Your dev server ID (right-click server icon → Copy Server ID)
# Only needed during development for instant command registration
DISCORD_GUILD_ID=your_guild_id_here

# ─── Discord Channel IDs ──────────────────────────────────────────────────────
# Right-click each channel → Copy Channel ID
FEED_CHANNEL_ID=your_adventure_feed_channel_id
FALLEN_CHANNEL_ID=your_tale_of_the_fallen_channel_id
DUNGEON_ACCESS_CHANNEL_ID=your_dungeon_access_channel_id
