# ─── API Server ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: switch LLM provider
# OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB URL — defaults to http://localhost:8001 when running via deno task up
# In Docker Compose, this is set automatically to http://vector-db:8000
CHROMA_URL=http://localhost:8001

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# The Discord bot has its own .env at d100-bot/.env
# Copy d100-bot/.env.example → d100-bot/.env and fill in your Discord credentials
